# Copy to .dev.vars (gitignored) for local development
# wrangler dev will load these automatically

# OpenRouter (free frontier models)
# NOTE: nvidia/llama-3.1-nemotron-ultra-253b-v1:free was RETIRED (OpenRouter 404)
# and is remapped at runtime by normalizeModel(); do not reintroduce it here.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_PRIMARY=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_FAST=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_CODE=qwen/qwen3-coder:free
LLM_MODEL_REASONING=gemini-2.5-flash

# Optional: independent free fallbacks tried when OpenRouter's shared free tier
# is exhausted. Workers AI (env.AI) is always-on and needs no key. Grok/Ollama
# are optional. Set these as Worker secrets, not here, in production.
# LLM_GROK_KEY=xai-...
# LLM_OLLAMA_URL=https://<your-ollama-host>
# LLM_MODEL_OLLAMA=llama3.3:70b
 
# Optimus journal — A/B flag for the daily-canvas conditioning path.
# Generation conditions on EXTRACTED THREADS (open questions / claims /
# unaddressed reader requests), not raw prior prose. This flag only controls
# whether the single most-recent entry's prose is also shown for voice
# continuity. Default (unset) = true. Set false to condition on threads alone.
# JOURNAL_INCLUDE_PRIOR_PROSE=false

CLOUDFLARE_ACCOUNT_ID=f60c2e6068e002f5dbad7cd562a5c165

# Connect-back sandbox — ONE shared secret, carried under two names (by design):
#   elle-worker   SANDBOX_AGENT_KEY   (this worker; compared to x-sandbox-key)
#   Elle app      ELLE_SANDBOX_KEY    (sent as x-sandbox-key when the agent polls
#                                      /api/sandbox-bus/poll + /submit)
# They MUST hold the same value. Unset ⇒ the worker's sandbox routes return 503
# and the Elle agent sits idle ("ELLE_SANDBOX_KEY not set; not polling").
# In production set it as a Worker secret, not here:
#   wrangler secret put SANDBOX_AGENT_KEY
# Or bind both sides in one shot:  ./scripts/set-sandbox-key.sh
# SANDBOX_AGENT_KEY=change-me-to-a-long-random-string

